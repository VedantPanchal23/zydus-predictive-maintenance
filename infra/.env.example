# Application database
APP_DB_NAME=zydus_db
APP_DB_USER=zydus_user
APP_DB_PASSWORD=zydus_pass
APP_DB_PORT=5432

# Service ports
BACKEND_PORT=8000
REDIS_PORT=6379
ZOOKEEPER_PORT=2181
KAFKA_PORT=9092
MLFLOW_PORT=5000
AIRFLOW_PORT=8080
GRAFANA_PORT=3001
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Application security
JWT_SECRET=change-this-before-production
PREDICTION_CACHE_TTL_SECONDS=300
ML_DB_RETRIES=3
ML_REDIS_RETRIES=3
INGEST_DB_RETRIES=3
ALERT_DB_RETRIES=3
ALERT_REDIS_RETRIES=3

# Alerting and business rules
CRITICAL_FAILURE_PROB_THRESHOLD=0.80
WARNING_FAILURE_PROB_THRESHOLD=0.40
CRITICAL_ANOMALY_THRESHOLD=0.90
WARNING_ANOMALY_THRESHOLD=0.70
CRITICAL_DAYS_TO_FAILURE_THRESHOLD=3
WARNING_DAYS_TO_FAILURE_THRESHOLD=14
CRITICAL_ALERT_COOLDOWN_HOURS=6
WARNING_ALERT_COOLDOWN_HOURS=2
PREDICTION_STALE_MINUTES=10

# Airflow metadata database
AIRFLOW_DB_NAME=airflow_db
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow_pass

# Airflow web/admin defaults
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin123
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_FERNET_KEY=b1J0YkF5VXhJcUpiU0tScVZDaDJrQzdENW5rQ0J5ejN2VFlJdHlnUm5MSQ==
AIRFLOW_WEBSERVER_SECRET_KEY=change-airflow-web-secret
AIRFLOW_ML_ETL_SCHEDULE=
# Airflow request rate limits are persisted in Redis via RATELIMIT_STORAGE_URI.

# MLflow
MLFLOW_ALLOWED_HOSTS=*

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Workers
CELERY_WORKER_CONCURRENCY=2
